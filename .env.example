# AI providers
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key

# Google Custom Search (for find-product-links)
GOOGLE_CSE_API_KEY=your_google_cse_api_key
GOOGLE_CSE_ID=your_google_cse_id

# eBay Browse API (optional — verified retail prices)
# Sign up at https://developer.ebay.com to get credentials.
# If not set, verified retail prices are skipped gracefully.
EBAY_CLIENT_ID=your_ebay_client_id
EBAY_CLIENT_SECRET=your_ebay_client_secret
