# AI providers
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key

# Google Custom Search (for find-product-links)
GOOGLE_CSE_API_KEY=your_google_cse_api_key
GOOGLE_CSE_ID=your_google_cse_id

# eBay Browse API (optional — verified retail prices)
# Sign up at https://developer.ebay.com to get credentials.
# If not set, verified retail prices are skipped gracefully.
EBAY_CLIENT_ID=your_ebay_client_id
EBAY_CLIENT_SECRET=your_ebay_client_secret

# Donations (Stripe Checkout)
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
# App URL for Stripe redirect (success/cancel). Use your production URL in prod.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feedback form (Resend)
# Get API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxx
# Email address to receive feedback
FEEDBACK_EMAIL=your-email@example.com
# (Optional) Sender address. Use verified domain. Default: Vinted Analyzer <onboarding@resend.dev> (testing only)
# FEEDBACK_FROM=Vinted Analyzer <feedback@yourdomain.com>
