# Groq API key (primary AI provider for listing analysis — free tier, generous quota)
# Get one at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API key (fallback for analysis + required for product link search via Google Search grounding)
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# DeepL API key (for translating result when user changes language; optional)
# Get a free key at https://www.deepl.com/pro-api (free tier: 500k chars/month)
# If not set, the app falls back to re-running Gemini analysis on locale change.
DEEPL_AUTH_KEY=
